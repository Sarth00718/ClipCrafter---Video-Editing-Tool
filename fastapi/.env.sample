# ============================================
# RAG Video Script Generator - Environment Variables
# ============================================
# Copy this file to .env and fill in your actual API keys

# ── Groq LLM API ──────────────────────────────────────
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL_NAME=llama-3.3-70b-versatile

# ── Image Generation Providers ────────────────────────
# Pollinations.ai (Free, no API key required - Default)
# URL: https://image.pollinations.ai/

# ── Stability.ai API ──────────────────────────────────
# Get your API key from: https://platform.stability.ai/account/keys
STABILITY_API_KEY=your_stability_api_key_here
STABILITY_API_URL=https://api.stability.ai/v2beta/stable-image/generate/sd3

# ── Google Gemini API ─────────────────────────────────
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Murf AI Text-to-Speech API ────────────────────────
# Get your API key from: https://murf.ai/
MURF_API_KEY=your_murf_api_key_here
MURF_API_URL=https://api.murf.ai/v1/speech/generate

# ── Embedding Model ───────────────────────────────────
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# ── Chunking Configuration ────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Retrieval Configuration ───────────────────────────
TOP_K=10
MMR_DIVERSITY_LAMBDA=0.5

# ── Upload Limits ─────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50

# ── Storage Paths ─────────────────────────────────────
UPLOAD_DIR=app/storage/uploads
INDEX_DIR=app/storage/indices
PARSED_DIR=app/storage/parsed
SCRIPTS_DIR=app/storage/scripts
PROJECTS_DIR=app/storage/projects

# ── Server Configuration ──────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ── FFmpeg Configuration ──────────────────────────────
# Optional: Set paths if FFmpeg is not in system PATH
# If left empty, will auto-detect from:
#   1. Local installation: ffmpeg-8.0.1-essentials_build/bin/
#   2. System PATH
# 
# Windows example (relative): FFMPEG_PATH=ffmpeg-8.0.1-essentials_build/bin/ffmpeg.exe
# Windows example (absolute): FFMPEG_PATH=C:/ffmpeg/bin/ffmpeg.exe
# Linux example: FFMPEG_PATH=/usr/bin/ffmpeg
FFMPEG_PATH=
FFPROBE_PATH=

# Set to true to use mock processor (no FFmpeg required, for testing only)
USE_MOCK_PROCESSOR=false
